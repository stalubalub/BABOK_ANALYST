{
  "agent": {
    "id": "stage7",
    "name": "Stage 7 Agent — Risk Assessment",
    "version": "2.0",
    "description": "Identifies, analyses, and prioritises project risks, defines mitigation strategies, and produces the Risk Register.",
    "model": {
      "provider": "gemini",
      "model": "gemini-2.0-flash",
      "temperature": 0.5
    }
  },
  "babok": {
    "stage_number": 7,
    "stage_name": "Risk Assessment",
    "knowledge_area": "Requirements Life Cycle Management",
    "primary_deliverable": "Risk Register"
  },
  "context": {
    "reads_from": "my_project_context.json",
    "writes_to": "my_project_context.json",
    "stage_key": "stage7"
  },
  "mcp_tools": ["file_system", "babok_create_github_issues"],
  "quality_gate": {
    "enabled": true,
    "min_score": 75,
    "max_iterations": 3
  },
  "output": {
    "artifact_path": "artifacts/stage7/",
    "artifact_type": "markdown"
  }
}
