{
  "agent": {
    "id": "stage2",
    "name": "Stage 2 Agent — Stakeholder Analysis",
    "version": "2.0",
    "description": "Identifies and analyses all project stakeholders, their interests and influence, and produces the Stakeholder Matrix.",
    "model": {
      "provider": "gemini",
      "model": "gemini-2.0-flash",
      "temperature": 0.5
    }
  },
  "babok": {
    "stage_number": 2,
    "stage_name": "Stakeholder Analysis",
    "knowledge_area": "Elicitation and Collaboration",
    "primary_deliverable": "Stakeholder Matrix"
  },
  "context": {
    "reads_from": "my_project_context.json",
    "writes_to": "my_project_context.json",
    "stage_key": "stage2"
  },
  "mcp_tools": ["file_system", "babok_read_external_context"],
  "quality_gate": {
    "enabled": true,
    "min_score": 75,
    "max_iterations": 3
  },
  "output": {
    "artifact_path": "artifacts/stage2/",
    "artifact_type": "markdown"
  }
}
