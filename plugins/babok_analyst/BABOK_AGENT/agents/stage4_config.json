{
  "agent": {
    "id": "stage4",
    "name": "Stage 4 Agent — Requirements Elicitation",
    "version": "2.0",
    "description": "Elicits, documents, and structures business requirements from stakeholders, and produces the Business Requirements Document (BRD).",
    "model": {
      "provider": "gemini",
      "model": "gemini-2.0-flash",
      "temperature": 0.5
    }
  },
  "babok": {
    "stage_number": 4,
    "stage_name": "Requirements Elicitation",
    "knowledge_area": "Elicitation and Collaboration",
    "primary_deliverable": "Business Requirements Document (BRD)"
  },
  "context": {
    "reads_from": "my_project_context.json",
    "writes_to": "my_project_context.json",
    "stage_key": "stage4"
  },
  "mcp_tools": ["file_system", "babok_create_jira_epic"],
  "quality_gate": {
    "enabled": true,
    "min_score": 75,
    "max_iterations": 3
  },
  "output": {
    "artifact_path": "artifacts/stage4/",
    "artifact_type": "markdown"
  }
}
