{
  "agent": {
    "id": "stage3",
    "name": "Stage 3 Agent — Current State Analysis (AS-IS)",
    "version": "2.0",
    "description": "Analyses the current state of business processes, identifies pain points and inefficiencies, and produces the AS-IS Process Model.",
    "model": {
      "provider": "gemini",
      "model": "gemini-2.0-flash",
      "temperature": 0.5
    }
  },
  "babok": {
    "stage_number": 3,
    "stage_name": "Current State Analysis (AS-IS)",
    "knowledge_area": "Strategy Analysis",
    "primary_deliverable": "AS-IS Process Model"
  },
  "context": {
    "reads_from": "my_project_context.json",
