  "mcp_tools": ["file_system"],
  "quality_gate": {
    "enabled": true,
    "min_score": 75,
    "max_iterations": 3
  },
  "output": {
    "artifact_path": "artifacts/stage3/",
    "artifact_type": "markdown"
  }
