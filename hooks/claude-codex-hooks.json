{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/babok-activate.cjs\"; exit 0",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\babok-activate.cjs\" }",
            "timeout": 120,
            "statusMessage": "Loading BABOK Analyst..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/babok-deactivate.cjs\"; exit 0",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\babok-deactivate.cjs\" }",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/babok-activate.cjs\"; exit 0",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\babok-activate.cjs\" }",
            "timeout": 120,
            "statusMessage": "Loading BABOK Analyst..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__.*babok.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/babok-gate.cjs\"",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\babok-gate.cjs\" }",
            "timeout": 30,
            "statusMessage": "Two-Key Journal gate..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__.*babok.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/babok-quality-gate.cjs\"",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\babok-quality-gate.cjs\" }",
            "timeout": 30,
            "statusMessage": "Scoring deliverable..."
          }
        ]
      }
    ]
  }
}
