{
  "mcpServers": {
    "babok": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/babok-mcp/bin/babok-mcp.js"],
      "env": {
        "BABOK_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}",
        "BABOK_PROJECTS_DIR": "${CLAUDE_PROJECT_DIR}/projects",
        "BABOK_AGENT_DIR": "${CLAUDE_PLUGIN_ROOT}/BABOK_AGENT/stages"
      }
    }
  }
}
